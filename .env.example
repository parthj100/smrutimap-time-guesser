# Environment Variables for SmrutiMap
# Copy to .env and fill in real values. Never commit real keys.

# Supabase Configuration (Settings > API in the Supabase dashboard)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Google Maps API Key (restrict to your domains + Maps JavaScript API in Google Cloud Console)
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Optional: Analytics and tracking
# VITE_ANALYTICS_ID=your_analytics_id
# VITE_SENTRY_DSN=your_sentry_dsn
